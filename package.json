{
  "name": "@jaredlikes/openclaw-plugin-ansible",
  "version": "0.1.2",
  "description": "Secure mesh coordination plugin for OpenClaw: ring-of-trust onboarding, CRDT sync, capability contracts, and governed delegation.",
  "type": "module",
  "main": "dist/index.js",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "types": "dist/index.d.ts",
  "files": [
    "dist/",
    "openclaw.plugin.json",
    "README.md"
  ],
  "openclaw": {
    "extensions": ["./dist/index.js"]
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "prepublishOnly": "npm run build",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "phase0:fixtures:refresh": "npm run build && node ./scripts/parity/generate-sla-sweep-phase0-fixtures.mjs",
    "test:parity:mvp6": "npm run build && node ./scripts/parity/check-sla-sweep-phase0-parity.mjs",
    "test:deploy:nonprod": "node ./scripts/nonprod-deploy-harness.mjs",
    "migrate:v2026.2.19": "node ./scripts/migrate-v2026-2-19.mjs",
    "deploy:safe": "./scripts/safe-deploy-pull.sh",
    "test:integration:smoke": "node ./scripts/integration-gateway-smoke.mjs",
    "test:integration:capability-lifecycle": "node ./scripts/integration-capability-lifecycle-smoke.mjs",
    "test:integration:mvp1-industrial": "node ./scripts/integration-mvp1-industrial-suite.mjs",
    "test:integration:mvp2-lifecycle-core": "node ./scripts/integration-mvp2-lifecycle-core.mjs",
    "test:integration:mvp2-rollback-drill": "node ./scripts/integration-mvp2-rollback-drill.mjs"
  },
  "keywords": [
    "openclaw",
    "plugin",
    "distributed",
    "coordination",
    "yjs",
    "crdt"
  ],
  "author": "Jared Likes",
  "homepage": "https://github.com/likesjx/openclaw-plugin-ansible",
  "bugs": {
    "url": "https://github.com/likesjx/openclaw-plugin-ansible/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/likesjx/openclaw-plugin-ansible.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT",
  "dependencies": {
    "yjs": "^13.6.0",
    "y-websocket": "^2.0.0",
    "ws": "^8.17.1"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/ws": "^8.0.0",
    "typescript": "^5.0.0"
  },
  "peerDependencies": {
    "openclaw": "*"
  },
  "engines": {
    "node": ">=22.22.0"
  }
}
